# ─── Backend login (SP-Projects) ──────────────────────────────
# Eén admin-account. Wijzig deze waarden voor productie/staging.
SP_ADMIN_EMAIL=info@sp-projects.be
SP_ADMIN_PASSWORD=sp-projects
# Geheime sleutel om de sessie-cookie te ondertekenen — maak iets willekeurigs.
SP_SESSION_SECRET=verander-mij-naar-iets-willekeurigs

# Zonder bovenstaande variabelen gebruikt de app veilige dev-defaults
# (login: info@sp-projects.be / sp-projects). Zet ze zeker voor productie.
